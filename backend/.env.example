APP_NAME="Decant Please"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8010
FRONTEND_URL=http://localhost:3001

# Filament admin login (seeded as admin@decantplease.local)
ADMIN_PASSWORD=

# Shown in the storefront footer via /api/v1/meta (leave blank to hide)
SOCIAL_TIKTOK_URL=
SOCIAL_FACEBOOK_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
# 5442, not Postgres's default 5432: that port is already taken on this dev machine.
# Only matters if you run Laravel outside Docker — compose pins DB_* to its own
# postgres service, where the port is a plain 5432.
DB_PORT=5442
DB_DATABASE=decant_please
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Disk for user-uploaded fragrance/brand images. Local dev uses "public"
# (served via `php artisan storage:link`); production sets MEDIA_DISK=s3 to store
# and serve them from Cloudflare R2. Kept separate from FILESYSTEM_DISK because the
# default disk is the private "local" one. See config/filesystems.php.
MEDIA_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Cloudflare R2 (S3-compatible) — production image storage, used when MEDIA_DISK=s3.
# Leave blank for local dev. On R2: AWS_DEFAULT_REGION is "auto", AWS_ENDPOINT is the
# S3 API endpoint (https://<account-id>.r2.cloudflarestorage.com), and AWS_URL is the
# bucket's public custom domain — it is baked into the image URLs the API returns.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=
AWS_ENDPOINT=

VITE_APP_NAME="${APP_NAME}"
