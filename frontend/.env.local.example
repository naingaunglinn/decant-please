# Laravel API base — the storefront appends /v1. Also decides where uploaded
# images are optimized from (see next.config.ts).
NEXT_PUBLIC_API_URL=http://localhost:8010/api

# Public site URL — canonical/OG metadata, sitemap, robots.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Production only: the Cloudflare R2 public image host, added to next.config.ts's image
# remotePatterns. Leave unset locally — in dev, images are served from the API host's
# /storage path, which is already allow-listed.
# NEXT_PUBLIC_IMAGE_URL=https://images.cornerarea.me
